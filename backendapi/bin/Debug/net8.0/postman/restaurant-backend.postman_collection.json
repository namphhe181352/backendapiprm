{
  "info": {
    "name": "Restaurant Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://localhost:5001" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}" }
      }
    },
    {
      "name": "Reservation - Check In",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/reservations/check-in",
        "body": { "mode": "raw", "raw": "{\n  \"tableId\": 1,\n  \"customerName\": \"Nguyen Van A\",\n  \"customerPhone\": \"0900000000\",\n  \"guestCount\": 2,\n  \"note\": \"Near window\"\n}" }
      }
    },
    {
      "name": "Order - Add Item",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/orders/1/items",
        "body": { "mode": "raw", "raw": "{\n  \"menuItemId\": 1,\n  \"quantity\": 2,\n  \"note\": \"Less spicy\"\n}" }
      }
    },
    {
      "name": "Checkout",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/checkout",
        "body": { "mode": "raw", "raw": "{\n  \"orderId\": 1,\n  \"paymentMethod\": \"cash\",\n  \"taxAmount\": 0,\n  \"discountAmount\": 0,\n  \"tipAmount\": 0\n}" }
      }
    },
    {
      "name": "Admin - Dashboard Summary",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/admin/dashboard/summary"
      }
    }
  ]
}
